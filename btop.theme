# RubyLLM Light theme for btop
# Warm light palette sampled from the RubyLLM Homepage 4.0 design

# Main background, empty for terminal default
theme[main_bg]="#f7f3f1"

# Main text color
theme[main_fg]="#3a3430"

# Title color for boxes
theme[title]="#3a3430"

# Highlight color for keyboard shortcuts
theme[hi_fg]="#b30000"

# Background color of selected item in processes box
theme[selected_bg]="#f2ddda"

# Foreground color of selected item in processes box
theme[selected_fg]="#b30000"

# Color of inactive/disabled text
theme[inactive_fg]="#726f6c"

# Color of text appearing on top of graphs, i.e uptime and current network graph scaling
theme[graph_text]="#57524f"

# Background color of the percentage meters
theme[meter_bg]="#d4d0cd"

# Misc colors for processes box including mini cpu graphs, details memory graph and details status text
theme[proc_misc]="#57524f"

# CPU, Memory, Network, Proc box outline colors
theme[cpu_box]="#287980"   # Teal
theme[mem_box]="#396847"   # Green
theme[net_box]="#9b5139"   # Warm brown
theme[proc_box]="#205ea6"  # Blue

# Box divider line and small boxes line color
theme[div_line]="#d4d0cd"

# Temperature graph color (Green -> Yellow -> Red)
theme[temp_start]="#396847"
theme[temp_mid]="#9b5139"
theme[temp_end]="#b30000"

# CPU graph colors (Teal -> Blue -> Warm rose)
theme[cpu_start]="#287980"
theme[cpu_mid]="#205ea6"
theme[cpu_end]="#a26958"

# Mem/Disk free meter (Warm rose -> Blue -> Teal)
theme[free_start]="#a26958"
theme[free_mid]="#4385be"
theme[free_end]="#287980"

# Mem/Disk cached meter (Blue -> Teal -> Rose)
theme[cached_start]="#4385be"
theme[cached_mid]="#287980"
theme[cached_end]="#cf5f5c"

# Mem/Disk available meter (Yellow -> Orange -> Red)
theme[available_start]="#d5a670"
theme[available_mid]="#9b5139"
theme[available_end]="#b30000"

# Mem/Disk used meter (Green -> Teal -> Blue)
theme[used_start]="#396847"
theme[used_mid]="#287980"
theme[used_end]="#205ea6"

# Download graph colors (Yellow -> Orange -> Red)
theme[download_start]="#d5a670"
theme[download_mid]="#9b5139"
theme[download_end]="#b30000"

# Upload graph colors (Green -> Teal -> Blue)
theme[upload_start]="#396847"
theme[upload_mid]="#287980"
theme[upload_end]="#205ea6"

# Process box color gradient for threads, mem and cpu usage (Teal -> Blue -> Rose)
theme[process_start]="#287980"
theme[process_mid]="#4385be"
theme[process_end]="#a26958"
